# ==============================================================================
# 🚀 ENTORNO DE FACTORÍA: Configuración de Monorepo / Microservicios (VPS)
# ==============================================================================
# Renombrar/Copiar este archivo a .env en el servidor VPS donde corre tu Portainer.
# Docker-Compose absorberá de aquí las credenciales para inyectarlas directamente al stack.

# ------------------------------------------------------------------------------
# 1. CORE & JWT (Requerido)
# ------------------------------------------------------------------------------
# URL central donde corre tu API (Usualmente la IP de tu VPS o el Dominio final)
SITE_URL=http://localhost
CORS_ORIGIN=http://localhost,http://127.0.0.1

# El token de seguridad firmado. ¡SÓLO REEMPLAZAR ESTE TEXTO EN PRODUCCIÓN!
# Mínimo 32 caracteres. Puedes generar uno seguro tipeando en consola: openssl rand -base64 32
JWT_SECRET=tu_super_secreto_generado_muy_largo_y_complejo_cambiar_por_favor

# Llave anónima firmada con tu JWT_SECRET para el rol "anon" (generarla en jwt.io)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiJ9.dummy_signature_change_me

# Superadmin creado automáticamente al levantar el stack
SUPERADMIN_EMAIL=superadmin@conozca.com
SUPERADMIN_PASSWORD=ChangeMe_StrongPassword_123!
SUPERADMIN_FULL_NAME=Makisaurio
SUPERADMIN_DRY_RUN=false

# URL PÚBLICA de tu VPS + el puerto del gateway (la URL que ve el navegador del usuario)
# IMPORTANTE: NO usar http://gateway:80 aquí, eso es solo interno de Docker
# Ejemplo: http://65.109.12.34:8080
NEXT_PUBLIC_SUPABASE_URL=http://204.168.239.69:8080

# ------------------------------------------------------------------------------
# 2. BASE DE DATOS POSTGRESQL (Requerido)
# ------------------------------------------------------------------------------
POSTGRES_PORT=5432
# ¡Contraseña fuerte para la base de datos! Las APIs internas se conectan usando esto.
POSTGRES_PASSWORD=tu_password_fuerte_de_base_de_datos

# ------------------------------------------------------------------------------
# 3. CONOZCA APP (Frontend)
# ------------------------------------------------------------------------------
# Estos impactan durante el Runtime del Framework Next.js Standalone
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# ------------------------------------------------------------------------------
# 4. EMAILS EN AUTENTICACIÓN / GOTRUE (Opcional - Recomendado para Prod)
# ------------------------------------------------------------------------------
# Si deseas que los registros de usuarios validen emails y soporten "Magic Links" o Reset OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_clave_de_aplicacion_smtp
SMTP_SENDER_NAME="Equipo Conozca"
